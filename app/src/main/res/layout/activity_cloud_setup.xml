<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amazon S3"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No rate limit - fastest upload"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvS3Status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etS3Access"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Access Key ID"
            android:inputType="text"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etS3Secret"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Secret Access Key"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etS3Bucket"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Bucket (default: ai2orbit-photos)"
            android:inputType="text"
            android:layout_marginTop="8dp"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etS3Region"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Region (default: us-east-1)"
            android:inputType="text"
            android:layout_marginTop="8dp"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveS3"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Save S3"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearS3"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Clear"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Azure Blob Storage"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No rate limit - same speed as S3"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvAzStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAzAccount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Storage Account Name"
            android:inputType="text"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAzKey"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Account Key"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAzContainer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Container (default: ai2orbit-photos)"
            android:inputType="text"
            android:layout_marginTop="8dp"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAzure"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Save Azure"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearAzure"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Clear"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
