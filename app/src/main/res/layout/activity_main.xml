<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="@color/bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI2ORBIT"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginTop="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Performance Photo Transport"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in with Google to upload photos"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="24dp"
        android:gravity="center" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignIn"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="Sign in with Google"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        style="@style/Widget.Material3.Button" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignOut"
        android:layout_width="280dp"
        android:layout_height="48dp"
        android:text="Sign Out"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <View
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBenchmark"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="Run Device Benchmark"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        style="@style/Widget.Material3.Button.TonalButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUpload"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:text="Upload Photos to Drive"
        android:textSize="16sp"
        android:enabled="false"
        android:layout_marginTop="12dp"
        style="@style/Widget.Material3.Button" />

    <TextView
        android:id="@+id/tvUploadHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in first to enable photo upload"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:layout_marginTop="8dp"
        android:gravity="center" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI2ORBIT Co. 2026"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="16dp" />

</LinearLayout>
