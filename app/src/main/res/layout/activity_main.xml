<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI2ORBIT"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Performance Photo Transport"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLOUD PROVIDER"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_hint"
            android:layout_marginTop="24dp" />

        <RadioGroup
            android:id="@+id/rgCloud"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbGoogle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Google"
                android:textSize="13sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbS3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="S3"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbAzure"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Azure"
                android:textSize="13sp" />

        </RadioGroup>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select cloud provider"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignIn"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Sign in with Google"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            style="@style/Widget.Material3.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloudSetup"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Cloud Setup (S3 / Azure)"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            style="@style/Widget.Material3.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignOut"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:text="Sign Out"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <View
            android:layout_width="200dp"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBenchmark"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Run Device Benchmark"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpload"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Upload Photos"
            android:textSize="16sp"
            android:enabled="false"
            android:layout_marginTop="12dp"
            style="@style/Widget.Material3.Button" />

        <TextView
            android:id="@+id/tvUploadHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure cloud first"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI2ORBIT Co. 2026"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>
